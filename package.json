{
  "name": "app-env",
  "version": "1.0.0",
  "description": "Docker environment with CI/CD",
  "private": true,
  "scripts": {
    "prepare": "husky install",
    "setup": "node scripts/setup.js",
    "setup:complete": "node scripts/complete-setup.js",
    "doctor": "node scripts/doctor.js",
    "test:env-tools": "node --test scripts/tests/*.test.js",
    "test": "cd react-app && npm test",
    "lint": "cd react-app && npm run lint",
    "format": "cd react-app && npm run format",
    "format:check": "cd react-app && npm run format:check",
    "e2e:up": "docker compose -f e2e/docker-compose.e2e.yml up -d --build",
    "e2e:down": "docker compose -f e2e/docker-compose.e2e.yml down -v",
    "e2e:test": "cd e2e && npm test"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "inquirer": "^13.3.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.1"
  },
  "engines": {
    "node": ">=24.13.1",
    "npm": ">=11.10.0"
  }
}
