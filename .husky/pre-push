#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

echo "🧪 Running tests before push..."

# Run all tests (local-only compose + env)
UNAME=$(uname -s 2>/dev/null || echo '')
if echo "$UNAME" | grep -qiE 'mingw|msys|cygwin'; then
  powershell -File scripts/test.ps1 -ComposeFile local.docker.yml -EnvFile .env.local
else
  ./scripts/test.sh --compose-file local.docker.yml --env-file .env.local
fi

if [ $? -eq 0 ]; then
  echo "✅ All tests passed! Proceeding with push..."
else
  echo "❌ Tests failed! Push aborted."
  echo "Fix the failing tests before pushing."
  exit 1
fi
