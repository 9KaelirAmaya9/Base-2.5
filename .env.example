# ============================================
# ENV Configuration
# ============================================

# Setup (required for first-run)
PROJECT_NAME=YOUR_PROJECT_NAME
WEBSITE_DOMAIN=YOUR_DOMAIN_HERE
ENV=development
DEPLOY_MODE=local
APPLY_DEV_DEFAULTS=false
USER_MAIN_EMAIL=YOUR_EMAIL_HERE
USER_MAIN_PASSWORD=YOUR_PASSWORD_HERE
USER_MAIN_NAME=YOUR_USERNAME_HERE
APPLY_USER_NAME_DEFAULTS=false
APPLY_USER_EMAIL_DEFAULTS=false
APPLY_USER_PASSWORD_DEFAULTS=false
TP_USER_IP_ADDRESS=YOUR_IP_ADDRESS_HERE

# Git (required for deploy)
GIT_REPO=YOUR_GIT_REPO_URL # REQUIRED for deploy
GIT_REPO_BRANCH=YOUR_GIT_BRANCH # REQUIRED for deploy

# Spec-Kit
SPEC_KIT_AI=copilot
# options: amp, auggie, bob, claude, codebuddy, codex, copilot, cursor-agent, gemini, kilocode, opencode, qoder, qwen, shai, windsurf
SPEC_KIT_SCRIPT=ps # options: ps or sh

# Template Defaults (Sensitive)
# Edit these once; values are referenced in service sections below.
TP_DJANGO_SECRET_KEY=YOUR_DJANGO_SECRET_KEY
TP_JWT_SECRET=YOUR_JWT_SECRET
TP_TOKEN_PEPPER=YOUR_TOKEN_PEPPER
TP_OAUTH_STATE_SECRET=YOUR_OAUTH_STATE_SECRET
TP_SEED_ADMIN_PASSWORD=YOUR_ADMIN_PASSWORD
TP_SEED_DEMO_PASSWORD=YOUR_DEMO_PASSWORD
TP_DJANGO_SUPERUSER_PASSWORD=YOUR_SUPERUSER_PASSWORD
TP_REDIS_PASSWORD=YOUR_REDIS_PASSWORD
TP_POSTGRES_PASSWORD=YOUR_POSTGRES_PASSWORD
TP_PGADMIN_PASSWORD=YOUR_PGADMIN_PASSWORD
TP_FLOWER_PASSWORD=YOUR_FLOWER_PASSWORD
TP_TRAEFIK_PASSWORD=YOUR_TRAEFIK_PASSWORD

# Runtime
DEPLOY_PATH=/opt/apps/

# ============================================
# Network Configuration
# ============================================
COMPOSE_PROJECT_NAME=${PROJECT_NAME}
NETWORK_NAME=${PROJECT_NAME}_network

# ============================================
# Celery Configuration
# ============================================
# Redis is internal-only (no published ports) but MUST still require auth.
# Note: If your password contains special URL characters, URL-encode it before embedding.
REDIS_PASSWORD=${TP_REDIS_PASSWORD}
CELERY_BROKER_URL=redis://:${REDIS_PASSWORD}@redis:6379/0
CELERY_RESULT_BACKEND=redis://:${REDIS_PASSWORD}@redis:6379/1
CELERY_LOG_LEVEL=INFO
CELERY_CONCURRENCY=2

# ============================================
# Django Configuration
# ============================================
DJANGO_PYTHON_VERSION=3.12-slim
DJANGO_SECRET_KEY=${TP_DJANGO_SECRET_KEY}
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=${WEBSITE_DOMAIN},admin.${WEBSITE_DOMAIN},django,api
DJANGO_PORT=8000
# Django superuser bootstrap (created at container start)
DJANGO_SUPERUSER_NAME=${USER_MAIN_NAME}
DJANGO_SUPERUSER_PASSWORD=${TP_DJANGO_SUPERUSER_PASSWORD}
DJANGO_SUPERUSER_EMAIL=${USER_MAIN_EMAIL}
DJANGO_ALLOW_ALL_HOSTS=true
DJANGO_SECURE_SSL_REDIRECT=false
# Django admin label (router host prefix)
# Dev-production policy: Django admin is served at https://admin.${WEBSITE_DOMAIN}/admin/
# Keep this value as "admin" unless you also update Traefik routing, DNS automation, and deploy probes.
DJANGO_ADMIN_DNS_LABEL=admin
DJANGO_ADMIN_ALLOWLIST=${TP_USER_IP_ADDRESS}/32

# ============================================
# FastAPI Configuration
# ============================================
FASTAPI_PYTHON_VERSION=3.12-slim
FASTAPI_PORT=5001

# FastAPI docs/OpenAPI exposure
# Default behavior:
# - ENV!=production: enabled
# - ENV=production: disabled unless you set API_DOCS_ENABLED=true
# Dev-production policy: enable docs so swagger subdomain can serve Swagger UI.
API_DOCS_ENABLED=true
API_DOCS_URL=/docs
API_OPENAPI_URL=/openapi.json
API_REDOC_URL=/redoc

# Dev-production policy: Swagger UI is served at https://swagger.${WEBSITE_DOMAIN}/docs

# ============================================
# Flower Configuration
# ============================================
# Flower dashboard
FLOWER_DNS_LABEL=flower
# Default Flower credentials (used to build FLOWER_BASIC_USERS)
FLOWER_USER_NAME=YOUR_FLOWER_USER
FLOWER_USER_PASSWORD=${TP_FLOWER_PASSWORD}
FLOWER_USER=${FLOWER_USER_NAME}
FLOWER_PASSWORD=${TP_FLOWER_PASSWORD}
# Escape $ as $$ in htpasswd format to avoid Compose interpolation warnings
# Example: admin:$$apr1$$... or admin:$2b$10$...
FLOWER_BASIC_USERS=YOUR_BCRYPT_HASH_HERE
FLOWER_ACTUAL_PW=YOUR_FLOWER_ACTUAL_PASSWORD
FLOWER_ALLOWLIST=${TP_USER_IP_ADDRESS}/32

# ============================================
# Nginx Configuration
# ============================================
NGINX_VERSION=1.25-alpine
NGINX_PORT=80
NGINX_HOST_PORT=8080
NGINX_WORKER_PROCESSES=auto
NGINX_WORKER_CONNECTIONS=1024

# ============================================
# PostgreSQL Configuration
# ============================================
POSTGRES_VERSION=16-alpine
POSTGRES_USER=${USER_MAIN_NAME}
POSTGRES_PASSWORD=${TP_POSTGRES_PASSWORD}
POSTGRES_DB=YOUR_DB_NAME
POSTGRES_PORT=5432
POSTGRES_HOST_PORT=5432
DB_HOST=postgres
DB_USER=${POSTGRES_USER}
DB_PASSWORD=${TP_POSTGRES_PASSWORD}
# Legacy alias (some older scripts may still reference DB_PASS)
DB_PASS=${TP_POSTGRES_PASSWORD}

# ============================================
# pgAdmin Configuration
# ============================================
PGADMIN_VERSION=latest
PGADMIN_DEFAULT_EMAIL=${USER_MAIN_EMAIL}
PGADMIN_DEFAULT_PASSWORD=${TP_PGADMIN_PASSWORD}
PGADMIN_PORT=8080
PGADMIN_HOST_PORT=5050
PGADMIN_CONFIG_SERVER_MODE=True
PGADMIN_DNS_LABEL=pgadmin
PGADMIN_ALLOWLIST=${TP_USER_IP_ADDRESS}/32

# ============================================
# React App Configuration
# ============================================
REACT_APP_NODE_VERSION=18-alpine
REACT_APP_PORT=3000
REACT_APP_HOST_PORT=3000
REACT_APP_API_URL=https://${WEBSITE_DOMAIN}/api

# ============================================
# Redis Configuration
# ============================================
REDIS_VERSION=7.2-alpine
REDIS_PORT=6379

# ============================================
# Traefik Configuration
# ============================================
TRAEFIK_VERSION=v3.1
TRAEFIK_PORT=80
TRAEFIK_API_PORT=8082
TRAEFIK_API_ENTRYPOINT=traefik
TRAEFIK_LOG_LEVEL=INFO
# Generated by setup
TRAEFIK_DOCKER_NETWORK=${NETWORK_NAME}
TRAEFIK_API_DEBUG=false
TRAEFIK_CERT_EMAIL=${USER_MAIN_EMAIL}
TRAEFIK_EXPOSED_BY_DEFAULT=false
TRAEFIK_DNS_LABEL=traefik

# Traefik ACME cert resolver
# Use staging by default to avoid accidentally issuing production certs.
# Production deployments should override this to `le`.
TRAEFIK_CERT_RESOLVER=le

# Default Traefik dashboard credentials (used to build TRAEFIK_DASH_BASIC_USERS)
TRAEFIK_USER_NAME=YOUR_TRAEFIK_USER
TRAEFIK_USER_PASSWORD=${TP_TRAEFIK_PASSWORD}
TRAEFIK_DASH_USER=${TRAEFIK_USER_NAME}
TRAEFIK_DASH_PASSWORD=${TP_TRAEFIK_PASSWORD}

# Traefik dashboard basic-auth users (htpasswd format: username:hash)
# Example: admin:$$apr1$$... or admin:$2b$10$...
# Note: double each '$' to prevent Compose from misinterpreting bcrypt parts as variables.
TRAEFIK_DASH_BASIC_USERS=YOUR_BCRYPT_HASH_HERE
TRAEFIK_ACTUAL_PW=YOUR_TRAEFIK_ACTUAL_PASSWORD

# Traefik security headers preset (use no-HSTS for staging certs)
SECURITY_HEADERS_MIDDLEWARE=security-headers-no-hsts

# JWT Configuration (CHANGE IN PRODUCTION!)
JWT_SECRET=${TP_JWT_SECRET}
# JWT token governance
# These are embedded into access tokens and validated on decode.
JWT_ISSUER=${PROJECT_NAME}
JWT_AUDIENCE=${PROJECT_NAME}
# Access-token TTL in minutes
JWT_EXPIRE=15

# Refresh token TTL in days
REFRESH_TOKEN_TTL_DAYS=30

# Token hashing pepper (separate from JWT secret; required in production)
TOKEN_PEPPER=${TP_TOKEN_PEPPER}

# If true, refresh token is set as an httpOnly cookie; if false, refresh token is returned in JSON.
AUTH_REFRESH_COOKIE=true

# Email Configuration (SMTP)
# If EMAIL_HOST is empty, Django will fall back to writing emails to the EmailOutbox table.
EMAIL_HOST=
EMAIL_PORT=587
# Supported aliases:
# - EMAIL_HOST_USER / EMAIL_HOST_PASSWORD (Django)
# - EMAIL_USER / EMAIL_PASSWORD (legacy, keep in sync)
EMAIL_HOST_USER=${USER_MAIN_EMAIL}
EMAIL_HOST_PASSWORD=
EMAIL_USER=${EMAIL_HOST_USER} # Legacy alias
EMAIL_PASSWORD=${EMAIL_HOST_PASSWORD} # Legacy alias
# Supported aliases:
# - DEFAULT_FROM_EMAIL (Django)
# - EMAIL_FROM (legacy)
DEFAULT_FROM_EMAIL=noreply@${WEBSITE_DOMAIN}
EMAIL_FROM=${DEFAULT_FROM_EMAIL}

# Seed data (dev/demo)
SEED_ADMIN_EMAIL=admin@${WEBSITE_DOMAIN}
SEED_ADMIN_PASSWORD=${TP_SEED_ADMIN_PASSWORD}
SEED_DEMO_PASSWORD=${TP_SEED_DEMO_PASSWORD}

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Auth & Security (required for cookie auth + CSRF)
SESSION_COOKIE_NAME=${PROJECT_NAME}_session
CSRF_COOKIE_NAME=${PROJECT_NAME}_csrf
COOKIE_SAMESITE=Lax
COOKIE_SECURE=true
DJANGO_INTERNAL_BASE_URL=http://django:8000
RATE_LIMIT_REDIS_PREFIX=rate_limit

# Google OAuth (Authorization Code flow)
GOOGLE_OAUTH_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID
GOOGLE_OAUTH_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET
GOOGLE_OAUTH_REDIRECT_URI=https://${WEBSITE_DOMAIN}/oauth/google/callback
OAUTH_STATE_SECRET=${TP_OAUTH_STATE_SECRET}

# ============================================
# Deploy (DigitalOcean)
# ============================================
# Core authentication
DO_API_TOKEN=YOUR_DO_API_TOKEN # REQUIRED for deploy

# Git repo to pull from (App Platform)
DO_GIT_REPO=${GIT_REPO} # REQUIRED for deploy
GIT_REMOTE=${GIT_REPO} # REQUIRED for deploy

# Core defaults
DO_DOMAIN=${WEBSITE_DOMAIN} # REQUIRED for deploy
DO_API_REGION=nyc3 # REQUIRED for deploy
DO_API_IMAGE=docker-20-04 # REQUIRED for deploy
DO_API_SIZE=s-1vcpu-2gb # REQUIRED for deploy
DO_SSH_KEY_ID=YOUR_DO_SSH_FINGERPRINT # REQUIRED for deploy
DO_API_SSH_KEYS=YOUR_DO_SSH_FINGERPRINTS
DO_APP_NAME=${PROJECT_NAME}-app # REQUIRED for deploy
DO_REGISTRY_NAME=${PROJECT_NAME}-registry
DO_APP_SPEC_PATH=digital_ocean/app_spec.yaml
DO_APP_BRANCH=${GIT_REPO_BRANCH} # REQUIRED for deploy

# Droplets API
DO_DROPLET_NAME=${PROJECT_NAME}-droplet
DO_DROPLET_SIZE=s-1vcpu-1gb
DO_DROPLET_IMAGE=docker-20-04
DO_DROPLET_COUNT=1
DO_DROPLET_PRIVATE_NETWORKING=true
DO_DROPLET_VOLUME_ID=

# Container Registry
DO_REPOSITORY_NAME=
DO_IMAGE_TAG=latest

# Spaces (S3-Compatible Storage)
DO_SPACES_KEY=
DO_SPACES_SECRET=
DO_SPACES_REGION=nyc3

# Observability
DO_APP_HEALTHCHECK_PATH=/api/health
DO_APP_HEALTHCHECK_INTERVAL=30
DO_APP_HEALTHCHECK_TIMEOUT=10
DO_APP_HEALTHCHECK_THRESHOLD=3

# Frontend URL for email verification links
FRONTEND_URL=https://${WEBSITE_DOMAIN}

# ============================================
# Advanced (optional)
# ============================================
DO_PROJECT_ID=
DO_FIREWALL_ID=
DO_VPC_UUID=
# Generated by setup
DO_TAGS=${PROJECT_NAME},automation
DO_MONITORING_ENABLED=true
DO_ALERT_EMAIL=${USER_MAIN_EMAIL}
DO_APP_DOMAIN=
DO_APP_REPO_URL=
DO_APP_AUTOSCALE=false
DO_APP_MIN_INSTANCES=1
DO_APP_MAX_INSTANCES=3
DO_API_TIMEOUT=60
DO_API_BASE_URL=https://api.digitalocean.com/v2
DO_DEPLOY_TIMEOUT=300
DO_TEARDOWN_TIMEOUT=120
DO_LOG_LEVEL=DEBUG
DO_API_RETRY_LIMIT=3
DO_API_RETRY_DELAY=5
DO_APP_ENV_EXAMPLE=VALUE


